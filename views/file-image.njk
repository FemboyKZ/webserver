<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta property="og:title" content="{{ fileName }}">
    <meta property="og:url" content="{{ siteUrl }}{{ currentPath }}">
    <meta property="og:type" content="article">
    <meta property="og:description" content="{{ sizeFormatted }} — {{ ext | upper }} image">
    <meta property="og:site_name" content="FKZ File Index">
    <meta property="og:image" content="{{ siteUrl }}{{ currentPath }}?raw=1">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="theme-color" content="#7e5dcc">
    <link rel="stylesheet" href="/static/style.css">
    <link rel="shortcut icon" href="/static/assets/fucker.ico">
</head>
<body>
    <h1>{{ fileName }}</h1>

    <nav>
        <a href="{{ parentPath }}">[Go Back]</a> |
        <a href="{{ currentPath }}?raw=1">[Download]</a>
    </nav>
    <br>

    <span class="file-meta">[{{ sizeFormatted }}] {{ date }}</span>
    <br><br>

    <div class="media-container">
        <img src="{{ currentPath }}?raw=1" alt="{{ fileName }}" class="media-preview">
    </div>

    <div class="media-info">
        <span>Format: {{ ext | upper }}</span>
        <span id="mediaRes"></span>
    </div>

    <script src="/static/helpers.js"></script>
    <script>initImageResolution();</script>
</body>
</html>
