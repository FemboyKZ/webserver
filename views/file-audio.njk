<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta property="og:title" content="{{ fileName }}">
    <meta property="og:url" content="{{ siteUrl }}{{ currentPath }}">
    <meta property="og:type" content="music.song">
    <meta property="og:description" content="{{ sizeFormatted }} — {{ ext | upper }} audio">
    <meta property="og:site_name" content="FKZ File Index">
    <meta property="og:audio" content="{{ siteUrl }}{{ currentPath }}?raw=1">
    <meta property="og:audio:type" content="audio/{{ mimeSubtype }}">
    <meta name="twitter:card" content="summary">
    <meta name="theme-color" content="#7e5dcc">
    <link rel="stylesheet" href="/static/style.css">
    <link rel="shortcut icon" href="/static/assets/fucker.ico">
</head>
<body>
    <h1>{{ fileName }}</h1>

    <nav>
        <a href="{{ parentPath }}">[Go Back]</a> |
        <a href="{{ currentPath }}?raw=1">[Download]</a>
    </nav>
    <br>

    <span class="file-meta">[{{ sizeFormatted }}] {{ date }}</span>
    <br><br>

    <div class="media-container player player-audio">
        <audio preload="metadata" class="media-audio">
            <source src="{{ currentPath }}?raw=1" type="audio/{{ mimeSubtype }}">
            Your browser does not support audio playback.
        </audio>
        <div class="player-controls">
            <button class="player-play"><i data-lucide="play"></i></button>
            <span class="player-time-current">0:00</span>
            <div class="player-progress">
                <div class="player-progress-buffer"></div>
                <div class="player-progress-fill"></div>
            </div>
            <span class="player-time-duration">0:00</span>
            <button class="player-mute"><i data-lucide="volume-2"></i></button>
            <input type="range" class="player-volume" min="0" max="1" step="0.05" value="1">
        </div>
    </div>

    <div class="media-info">
        <span>Format: {{ ext | upper }}</span>
        <span id="mediaDuration"></span>
        <span id="mediaChannels"></span>
        <span id="mediaSampleRate"></span>
    </div>

    <script src="https://unpkg.com/lucide@0.577.0/dist/umd/lucide.min.js"></script>
    <script>lucide.createIcons();</script>
    <script src="/static/player.js"></script>
</body>
</html>
