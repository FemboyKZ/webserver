<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta property="og:title" content="{{ fileName }}">
    <meta property="og:url" content="{{ siteUrl }}{{ currentPath }}">
    <meta property="og:type" content="website">
    <meta property="og:description" content="{{ sizeFormatted }} — {{ ext | upper }} file">
    <meta property="og:site_name" content="FKZ File Index">
    <meta name="twitter:card" content="summary">
    <meta name="theme-color" content="#7e5dcc">
    <link rel="stylesheet" href="/static/style.css?v={{ assetV('style.css') }}">
    <link rel="shortcut icon" href="/static/assets/fucker.ico?v={{ assetV('assets/fucker.ico') }}">
</head>
<body>
    <h1>{{ fileName }}</h1>

    <nav>
        <a href="{{ parentPath }}">[Go Back]</a> |
        <a href="{{ currentPath }}?raw=1">[Download]</a>
    </nav>
    <br>

    <span class="file-meta">[{{ sizeFormatted }}] {{ date }}</span>
    <br>
    <span class="file-meta">{{ ext | upper }} file</span>
    <br>
    <span class="file-meta">SHA-256: {{ sha256 }}</span>
    <br>
    <span class="file-meta">MD5: {{ md5 }}</span>
    <br><br>

    <p>No preview available for this file type.</p>
</body>
</html>
