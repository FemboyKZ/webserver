<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta property="og:title" content="{{ entryName }}">
    <meta property="og:url" content="{{ siteUrl }}{{ currentPath }}?file={{ entryName | urlencode }}">
    <meta property="og:type" content="website">
    <meta property="og:description" content="{{ sizeFormatted }} — {{ ext | upper }} file inside {{ archiveName }}">
    <meta property="og:site_name" content="FKZ File Index">
    {% if viewType == "image" %}
    <meta property="og:image" content="{{ siteUrl }}{{ currentPath }}?file={{ entryName | urlencode }}&raw=1">
    <meta name="twitter:card" content="summary_large_image">
    {% else %}
    <meta name="twitter:card" content="summary">
    {% endif %}
    <meta name="theme-color" content="#7e5dcc">
    <link rel="stylesheet" href="/static/style.css">
    <link rel="shortcut icon" href="/static/assets/fucker.ico">
</head>
<body>
    <h1>{{ entryName }}</h1>

    <nav>
        <a href="{{ archivePath }}">[Back to Archive]</a> |
        <a href="{{ currentPath }}?file={{ entryName | urlencode }}&raw=1">[Download]</a>
        {% if viewType == "text" %}
         | <a href="#" id="copy-btn" onclick="copyFileContent(); return false;">[Copy Text]</a>
        {% endif %}
    </nav>
    <br>

    <span class="file-meta">Inside: {{ archiveName }}</span>
    <br>
    <span class="file-meta">[{{ sizeFormatted }}]{% if date %} {{ date }}{% endif %}</span>

    {% if viewType == "text" %}
    <br>
    <span class="file-meta">{{ encoding }} | {{ lineEnding }} | {{ charCount }} chars | {{ lineCount }} lines</span>
    <br><br>

    {% if content %}
    <div class="file-content">
        <table class="line-table">
{%- for line in lines %}
            <tr><td class="line-number">{{ loop.index }}</td><td class="line-text">{{ line }}</td></tr>
{%- endfor %}
        </table>
    </div>
    {% else %}
    <p>File is empty.</p>
    {% endif %}

    {% elif viewType == "image" %}
    <br><br>
    <div class="media-container">
        <img src="{{ currentPath }}?file={{ entryName | urlencode }}&raw=1" alt="{{ entryName }}" class="media-preview">
    </div>
    <div class="media-info">
        <span>Format: {{ ext | upper }}</span>
        <span id="mediaRes"></span>
    </div>
    <script>
      const img = document.querySelector(".media-preview");
      function updateInfo() {
        if (img.naturalWidth) {
          document.getElementById("mediaRes").textContent =
            "Resolution: " + img.naturalWidth + " \u00d7 " + img.naturalHeight;
        }
      }
      if (img.complete) updateInfo();
      else img.addEventListener("load", updateInfo);
    </script>

    {% else %}
    <br>
    <span class="file-meta">{{ ext | upper }} file</span>
    <br><br>
    <p>No preview available for this file type.</p>
    {% endif %}

    {% if viewType == "text" %}
    <script>
    function copyFileContent() {
        const cells = document.querySelectorAll(".line-text");
        const text = Array.from(cells).map(c => c.textContent).join("\n");
        navigator.clipboard.writeText(text).then(() => {
            const btn = document.getElementById("copy-btn");
            const original = btn.textContent;
            btn.textContent = "[Copied!]";
            setTimeout(() => { btn.textContent = original; }, 1500);
        });
    }
    </script>
    {% endif %}
</body>
</html>
